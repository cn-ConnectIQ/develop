# ── 数据库 ──
# 应用运行时（Session Pooler，推荐）
DATABASE_URL="postgresql://postgres.[ID]:[密码]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require"
# Direct Connection（Prisma CLI / IPv6 环境）
DATABASE_URL_DIRECT="postgresql://postgres:[密码]@db.[ID].supabase.co:5432/postgres?sslmode=require"
# 运行时用（Transaction Pooler）
DATABASE_URL_POOLER="postgresql://postgres.[ID]:[密码]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL="https://[ID].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon key]"
SUPABASE_SERVICE_ROLE_KEY="[service role key]"

# ── Auth ──
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="[node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\"]"

# 公开站点 URL（二维码、邀请链接；测试环境填 https://marketingprofs.ai）
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── AI ──
ANTHROPIC_API_KEY="sk-ant-..."

# ── 短信（阿里云）──
ALIYUN_ACCESS_KEY_ID="..."
ALIYUN_ACCESS_KEY_SECRET="..."
ALIYUN_SMS_SIGN_NAME="ConnectIQ"
ALIYUN_SMS_TEMPLATE_CODE="SMS_..."
