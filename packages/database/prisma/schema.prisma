generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLATFORM_ADMIN
  ORGANIZER
  EXPO_ORGANIZER
  EXHIBITOR
}

enum EventType {
  CONFERENCE
  EXPO
}

enum EventStatus {
  DRAFT
  PUBLISHED
  LIVE
  ARCHIVED
}

enum ParticipantRole {
  ATTENDEE
  SPEAKER
}

enum BoothStatus {
  AVAILABLE
  BOOKED
  OCCUPIED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  WON
}

enum CrmSyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum TicketStatus {
  ISSUED
  USED
  CANCELLED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum PollType {
  SINGLE_CHOICE
  MULTI_CHOICE
  WORD_CLOUD
  RATING
  QNA
  ANNOUNCEMENT
}

enum PollStatus {
  DRAFT
  LIVE
  PAUSED
  CLOSED
}

enum AiMatchScenario {
  PARTICIPANT_PEER
  EXHIBITOR_TO_BUYER
  BUYER_TO_EXHIBITOR
}

enum AiMatchAction {
  PENDING
  VIEWED
  CONTACTED
  MEETING_BOOKED
  IGNORED
}

enum AiGenerationType {
  SCAN_BRIEF
  CONNECTION_NOTE
  FOLLOWUP_EMAIL
  INTRO_MESSAGE
  MONTHLY_INSIGHT
}

enum AiPromptStatus {
  ACTIVE
  DEPRECATED
}

enum AiQualityRating {
  EXCELLENT
  PASS
  NEEDS_WORK
}

enum MonthlyInsightStatus {
  PENDING
  GENERATED
  FAILED
}

enum AiFeedbackType {
  MATCH_USEFUL
  MATCH_USELESS
  TIMING_ACCURATE
  TIMING_INACCURATE
  CONTENT_QUALITY
  CONTENT_POOR
}

enum IntentCategory {
  TRADING
  INVESTING
  PARTNERING
  RECRUITING
  NETWORKING
}

enum SnSessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserAccountStatus {
  SHADOW
  ACTIVE
  COMPLETE
  BANNED
}

enum RegistrationSource {
  EMAIL
  PHONE
  WECHAT
  IMPORT
}

enum ConnectionSource {
  SCAN
  AI_RECOMMEND
  SPEED_NETWORKING
  REFERRAL
}

enum ConnectionStatus {
  ACTIVE
  INACTIVE
  DISCONNECTED
}

enum PointsReason {
  CHECKIN
  CONNECTION
  INTERACTION
  PROFILE
  REFERRAL
  REDEMPTION
  ADJUSTMENT
}

enum FeedItemType {
  MATCH
  INSIGHT
  REMINDER
  SYSTEM
}

enum InviteCampaignStatus {
  DRAFT
  SENDING
  SENT
  FAILED
  SCHEDULED
}

enum InviteChannel {
  SMS
  EMAIL
  WECHAT
}

enum InviteRecordStatus {
  PENDING
  SENT
  DELIVERED
  CLICKED
  ACTIVATED
  FAILED
  SKIPPED
}

enum ParticipantInviteStatus {
  NOT_INVITED
  INVITED
  CLICKED
  ACTIVATED
}

enum LotteryType {
  RANDOM
  QUIZ_BASED
  CHECKIN_BASED
  ACTIVITY_BASED
}

enum LotteryStatus {
  DRAFT
  READY
  OPEN
  DRAWING
  FINISHED
}

enum LotteryEntrySource {
  MANUAL
  AUTO_CHECKIN
  AUTO_ACTIVITY
}

enum InteractionChannelType {
  QR_CODE
  LINK
  APP_PUSH
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  phone        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roleAssignments            UserRoleAssignment[]
  organizedEvents            Event[]              @relation("EventOrganizer")
  createdPolls               Poll[]               @relation("PollCreator")
  booths                     Booth[]
  notifications              Notification[]
  auditLogs                  AuditLog[]
  fileAssets                 FileAsset[]
  apiKeys                    ApiKey[]
  monthlyInsights            MonthlyInsight[]
  aiFeedbacks                AiFeedback[]
  profile                    UserProfile?
  identities                 UserIdentity[]
  pointsLedger               PointsLedger[]
  feedItems                  FeedItem[]
  connectionsAsA             BusinessConnection[] @relation("ConnectionUserA")
  connectionsAsB             BusinessConnection[] @relation("ConnectionUserB")
  createdCampaigns           InviteCampaign[]     @relation("CampaignCreator")
  inviteRecords              InviteRecord[]
  createdLotteries           Lottery[]            @relation("LotteryCreator")
  lotteryEntries             LotteryEntry[]
  lotteryWins                LotteryWinner[]
  createdInteractionSessions InteractionSession[] @relation("InteractionSessionCreator")

  @@map("users")
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  role      UserRole
  entityId  String?  @map("entity_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role, entityId])
  @@map("user_role_assignments")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?  @map("logo_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  events Event[]

  @@map("organizations")
}

model Event {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  type           EventType
  status         EventStatus @default(DRAFT)
  description    String?
  location       String?
  startDate      DateTime?   @map("start_date")
  endDate        DateTime?   @map("end_date")
  organizerId    String      @map("organizer_id")
  organizationId String?     @map("organization_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organizer           User                 @relation("EventOrganizer", fields: [organizerId], references: [id])
  organization        Organization?        @relation(fields: [organizationId], references: [id])
  settings            EventSetting[]
  halls               ExpoHall[]
  booths              Booth[]
  participants        Participant[]
  intentTags          IntentTag[]
  ticketTypes         TicketType[]
  sessions            Session[]
  speakers            Speaker[]
  sponsors            Sponsor[]
  invitations         Invitation[]
  checkIns            CheckIn[]
  surveys             Survey[]
  polls               Poll[]
  externalSyncs       ExternalSync[]
  crmSyncJobs         CrmSyncJob[]
  aiMatchResults      AiMatchResult[]
  businessConnections BusinessConnection[]
  snSessions          SnSession[]
  inviteCampaigns     InviteCampaign[]
  lotteries           Lottery[]
  interactionSessions InteractionSession[]

  @@map("events")
}

model ExternalSync {
  id         String   @id @default(cuid())
  eventId    String   @map("event_id")
  provider   String   @default("marketup")
  fieldMap   Json     @default("{}") @map("field_map")
  syncConfig Json?    @map("sync_config")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, provider])
  @@map("external_syncs")
}

model PlatformIntegration {
  provider   String   @id
  fieldMap   Json     @default("{}") @map("field_map")
  syncConfig Json?    @map("sync_config")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("platform_integrations")
}

model CrmSyncJob {
  id            String        @id @default(cuid())
  leadId        String        @map("lead_id")
  eventId       String        @map("event_id")
  status        CrmSyncStatus @default(PENDING)
  errorMessage  String?       @map("error_message")
  attempts      Int           @default(0)
  lastAttemptAt DateTime?     @map("last_attempt_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  lead  Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("crm_sync_jobs")
}

model EventSetting {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  key       String
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, key])
  @@map("event_settings")
}

model ExpoHall {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  name      String
  floor     String?
  createdAt DateTime @default(now()) @map("created_at")

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  booths Booth[]

  @@map("expo_halls")
}

model Booth {
  id             String      @id @default(cuid())
  name           String
  code           String
  status         BoothStatus @default(AVAILABLE)
  eventId        String      @map("event_id")
  hallId         String?     @map("hall_id")
  exhibitorId    String      @map("exhibitor_id")
  positionData   Json?       @map("position_data")
  leadFormConfig Json?       @map("lead_form_config")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  event               Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  hall                ExpoHall?            @relation(fields: [hallId], references: [id])
  exhibitor           User                 @relation(fields: [exhibitorId], references: [id])
  bookings            BoothBooking[]
  leads               Lead[]
  lotteries           Lottery[]
  interactionSessions InteractionSession[]

  @@unique([eventId, code])
  @@map("booths")
}

model BoothBooking {
  id            String             @id @default(cuid())
  boothId       String             @map("booth_id")
  participantId String?            @map("participant_id")
  status        RegistrationStatus @default(PENDING)
  bookedAt      DateTime           @default(now()) @map("booked_at")

  booth       Booth        @relation(fields: [boothId], references: [id], onDelete: Cascade)
  participant Participant? @relation(fields: [participantId], references: [id])

  @@map("booth_bookings")
}

model Participant {
  id           String                  @id @default(cuid())
  eventId      String                  @map("event_id")
  name         String
  email        String?
  phone        String?
  company      String?
  jobTitle     String?                 @map("job_title")
  badgeQr      String?                 @unique @map("badge_qr")
  role         ParticipantRole         @default(ATTENDEE) @map("role")
  inviteStatus ParticipantInviteStatus @default(NOT_INVITED) @map("invite_status")
  createdAt    DateTime                @default(now()) @map("created_at")

  event           Event                     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations   ParticipantRegistration[]
  boothBookings   BoothBooking[]
  tickets         Ticket[]
  leads           Lead[]
  checkIns        CheckIn[]
  surveyResponses SurveyResponse[]
  pollResponses   PollResponse[]
  snPairsAsA      SnPair[]                  @relation("SnPairParticipantA")
  snPairsAsB      SnPair[]                  @relation("SnPairParticipantB")
  inviteRecords   InviteRecord[]

  @@map("participants")
}

model ParticipantRegistration {
  id            String             @id @default(cuid())
  participantId String             @map("participant_id")
  ticketTypeId  String?            @map("ticket_type_id")
  status        RegistrationStatus @default(PENDING)
  registeredAt  DateTime           @default(now()) @map("registered_at")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  ticketType  TicketType? @relation(fields: [ticketTypeId], references: [id])

  @@map("participant_registrations")
}

model IntentTag {
  id        String          @id @default(cuid())
  eventId   String?         @map("event_id")
  label     String
  slug      String
  category  IntentCategory?
  color     String?
  sortOrder Int             @default(0) @map("sort_order")
  createdAt DateTime        @default(now()) @map("created_at")

  event Event?          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  leads LeadIntentTag[]

  @@unique([eventId, slug])
  @@map("intent_tags")
}

model Lead {
  id                String        @id @default(cuid())
  boothId           String        @map("booth_id")
  participantId     String        @map("participant_id")
  status            LeadStatus    @default(NEW)
  intentGrade       String?       @map("intent_grade")
  notes             String?
  crmSyncStatus     CrmSyncStatus @default(PENDING) @map("crm_sync_status")
  crmSyncError      String?       @map("crm_sync_error")
  crmSyncedAt       DateTime?     @map("crm_synced_at")
  marketupContactId String?       @map("marketup_contact_id")
  marketupLeadId    String?       @map("marketup_lead_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  booth       Booth           @relation(fields: [boothId], references: [id], onDelete: Cascade)
  participant Participant     @relation(fields: [participantId], references: [id], onDelete: Cascade)
  intentTags  LeadIntentTag[]
  crmSyncJobs CrmSyncJob[]

  @@map("leads")
}

model LeadIntentTag {
  leadId      String @map("lead_id")
  intentTagId String @map("intent_tag_id")

  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  intentTag IntentTag @relation(fields: [intentTagId], references: [id], onDelete: Cascade)

  @@id([leadId, intentTagId])
  @@map("lead_intent_tags")
}

model TicketType {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  name      String
  price     Decimal  @default(0) @db.Decimal(10, 2)
  quota     Int?
  createdAt DateTime @default(now()) @map("created_at")

  event         Event                     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets       Ticket[]
  registrations ParticipantRegistration[]

  @@map("ticket_types")
}

model Ticket {
  id            String       @id @default(cuid())
  ticketTypeId  String       @map("ticket_type_id")
  participantId String       @map("participant_id")
  code          String       @unique
  status        TicketStatus @default(ISSUED)
  issuedAt      DateTime     @default(now()) @map("issued_at")

  ticketType  TicketType  @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("tickets")
}

model Session {
  id        String    @id @default(cuid())
  eventId   String    @map("event_id")
  title     String
  room      String?
  startTime DateTime? @map("start_time")
  endTime   DateTime? @map("end_time")
  createdAt DateTime  @default(now()) @map("created_at")

  event    Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speakers SessionSpeaker[]

  @@map("sessions")
}

model Speaker {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  name      String
  title     String?
  bio       String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")

  event    Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sessions SessionSpeaker[]

  @@map("speakers")
}

model SessionSpeaker {
  sessionId String @map("session_id")
  speakerId String @map("speaker_id")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@id([sessionId, speakerId])
  @@map("session_speakers")
}

model Sponsor {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  name      String
  level     String?
  logoUrl   String?  @map("logo_url")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("sponsors")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  title     String
  body      String
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model FileAsset {
  id         String   @id @default(cuid())
  uploaderId String   @map("uploader_id")
  url        String
  filename   String
  mimeType   String   @map("mime_type")
  size       Int
  createdAt  DateTime @default(now()) @map("created_at")

  uploader User @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@map("file_assets")
}

model WebhookLog {
  id          String        @id @default(cuid())
  source      String
  payload     Json
  status      WebhookStatus @default(RECEIVED)
  processedAt DateTime?     @map("processed_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@map("webhook_logs")
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  name      String
  keyHash   String    @map("key_hash")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Invitation {
  id         String           @id @default(cuid())
  eventId    String           @map("event_id")
  email      String
  role       UserRole
  token      String           @unique
  status     InvitationStatus @default(PENDING)
  acceptedAt DateTime?        @map("accepted_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model CheckIn {
  id            String   @id @default(cuid())
  eventId       String   @map("event_id")
  participantId String   @map("participant_id")
  method        String   @default("manual")
  checkedInAt   DateTime @default(now()) @map("checked_in_at")

  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("check_ins")
}

model Survey {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  title     String
  questions Json
  createdAt DateTime @default(now()) @map("created_at")

  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  responses SurveyResponse[]

  @@map("surveys")
}

model SurveyResponse {
  id            String   @id @default(cuid())
  surveyId      String   @map("survey_id")
  participantId String   @map("participant_id")
  answers       Json
  submittedAt   DateTime @default(now()) @map("submitted_at")

  survey      Survey      @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("survey_responses")
}

model Poll {
  id           String     @id @default(cuid())
  eventId      String     @map("event_id")
  createdById  String     @map("created_by_id")
  type         PollType
  title        String
  status       PollStatus @default(DRAFT)
  showResults  Boolean    @default(true) @map("show_results")
  closesAt     DateTime?  @map("closes_at")
  scheduledAt  DateTime?  @map("scheduled_at")
  displayOrder Int        @default(0) @map("display_order")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  event              Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy          User           @relation("PollCreator", fields: [createdById], references: [id])
  options            PollOption[]
  responses          PollResponse[]
  lotteriesRequiring Lottery[]      @relation("LotteryRequirePoll")
  lotteriesAsQuiz    Lottery[]      @relation("LotteryQuizPoll")

  @@map("polls")
}

model PollOption {
  id           String @id @default(cuid())
  pollId       String @map("poll_id")
  text         String
  displayOrder Int    @default(0) @map("display_order")

  poll      Poll           @relation(fields: [pollId], references: [id], onDelete: Cascade)
  responses PollResponse[] @relation("PollResponseOptions")

  @@map("poll_options")
}

model PollResponse {
  id            String   @id @default(cuid())
  pollId        String   @map("poll_id")
  participantId String?  @map("participant_id")
  optionId      String?  @map("option_id")
  textAnswer    String?  @map("text_answer")
  rating        Int?
  isOnScreen    Boolean  @default(false) @map("is_on_screen")
  createdAt     DateTime @default(now()) @map("created_at")

  poll        Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  participant Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  option      PollOption?  @relation("PollResponseOptions", fields: [optionId], references: [id], onDelete: SetNull)

  @@map("poll_responses")
}

model Lottery {
  id             String        @id @default(cuid())
  eventId        String        @map("event_id")
  createdById    String        @map("created_by")
  boothId        String?       @map("booth_id")
  title          String
  description    String?
  type           LotteryType   @default(RANDOM)
  status         LotteryStatus @default(DRAFT)
  prizes         Json          @default("[]")
  requireCheckin Boolean       @default(false) @map("require_checkin")
  requirePollId  String?       @map("require_poll_id")
  eligibleRoles  String[]      @default([]) @map("eligible_roles")
  quizPollId     String?       @map("quiz_poll_id")
  winnerCount    Int           @default(1) @map("winner_count")
  allowReenter   Boolean       @default(false) @map("allow_reenter")
  entryCount     Int           @default(0) @map("entry_count")
  drawnAt        DateTime?     @map("drawn_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  event       Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  creator     User            @relation("LotteryCreator", fields: [createdById], references: [id])
  booth       Booth?          @relation(fields: [boothId], references: [id], onDelete: SetNull)
  requirePoll Poll?           @relation("LotteryRequirePoll", fields: [requirePollId], references: [id], onDelete: SetNull)
  quizPoll    Poll?           @relation("LotteryQuizPoll", fields: [quizPollId], references: [id], onDelete: SetNull)
  entries     LotteryEntry[]
  winners     LotteryWinner[]

  @@index([eventId, status])
  @@map("lotteries")
}

model LotteryEntry {
  id        String             @id @default(cuid())
  lotteryId String             @map("lottery_id")
  userId    String             @map("user_id")
  source    LotteryEntrySource @default(MANUAL)
  enteredAt DateTime           @default(now()) @map("entered_at")

  lottery Lottery @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lotteryId, userId])
  @@index([lotteryId])
  @@map("lottery_entries")
}

model LotteryWinner {
  id        String   @id @default(cuid())
  lotteryId String   @map("lottery_id")
  userId    String   @map("user_id")
  prizeRank Int      @map("prize_rank")
  prizeName String   @map("prize_name")
  drawnAt   DateTime @default(now()) @map("drawn_at")
  notified  Boolean  @default(false)

  lottery Lottery @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lotteryId])
  @@map("lottery_winners")
}

model InteractionSession {
  id               String                 @id @default(cuid())
  eventId          String                 @map("event_id")
  boothId          String?                @map("booth_id")
  createdById      String                 @map("created_by")
  name             String
  sessionCode      String                 @unique @map("session_code")
  qrUrl            String?                @map("qr_url")
  interactions     Json                   @default("[]")
  channelType      InteractionChannelType @default(QR_CODE) @map("channel_type")
  isActive         Boolean                @default(true) @map("is_active")
  scanCount        Int                    @default(0) @map("scan_count")
  participantCount Int                    @default(0) @map("participant_count")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  booth   Booth? @relation(fields: [boothId], references: [id], onDelete: SetNull)
  creator User   @relation("InteractionSessionCreator", fields: [createdById], references: [id])

  @@index([eventId])
  @@index([sessionCode])
  @@map("interaction_sessions")
}

model AiMatchResult {
  id           String          @id @default(cuid())
  eventId      String?         @map("event_id")
  userAName    String          @map("user_a_name")
  userACompany String?         @map("user_a_company")
  userBName    String          @map("user_b_name")
  userBCompany String?         @map("user_b_company")
  score        Int
  reason       String
  scenario     AiMatchScenario
  action       AiMatchAction   @default(PENDING)
  connected    Boolean         @default(false)
  createdAt    DateTime        @default(now()) @map("created_at")

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@map("ai_match_results")
}

model AiGenerationLog {
  id             String           @id @default(cuid())
  type           AiGenerationType
  promptVersion  String           @map("prompt_version")
  tokensUsed     Int              @map("tokens_used")
  adopted        Boolean          @default(false)
  edited         Boolean          @default(false)
  contentPreview String?          @map("content_preview")
  qualityRating  AiQualityRating? @map("quality_rating")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@map("ai_generation_logs")
}

model AiPromptVersion {
  id        String           @id @default(cuid())
  version   String
  type      AiGenerationType
  adoption  Float            @default(0)
  editRate  Float            @default(0) @map("edit_rate")
  avgTokens Int              @default(0) @map("avg_tokens")
  status    AiPromptStatus   @default(ACTIVE)
  createdAt DateTime         @default(now()) @map("created_at")

  @@unique([version, type])
  @@map("ai_prompt_versions")
}

model MonthlyInsight {
  id          String               @id @default(cuid())
  userId      String               @map("user_id")
  period      String
  content     String
  actions     Json                 @default("[]")
  viewed      Boolean              @default(false)
  status      MonthlyInsightStatus @default(PENDING)
  generatedAt DateTime?            @map("generated_at")
  createdAt   DateTime             @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@map("monthly_insights")
}

model AiFeedback {
  id             String         @id @default(cuid())
  userId         String?        @map("user_id")
  type           AiFeedbackType
  negativeReason String?        @map("negative_reason")
  positive       Boolean
  createdAt      DateTime       @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("ai_feedbacks")
}

model AiFeedbackAnalysis {
  id          String   @id @default(cuid())
  text        String
  basedOn     Int      @map("based_on")
  generatedAt DateTime @default(now()) @map("generated_at")

  @@map("ai_feedback_analyses")
}

model UserProfile {
  userId             String             @id @map("user_id")
  company            String?
  industry           String?
  valueProposition   String?            @map("value_proposition")
  intentTags         Json               @default("[]")
  accountStatus      UserAccountStatus  @default(ACTIVE) @map("account_status")
  registrationSource RegistrationSource @default(EMAIL) @map("registration_source")
  pointsBalance      Int                @default(0) @map("points_balance")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserIdentity {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  provider  String
  value     String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("user_identities")
}

model BusinessConnection {
  id            String           @id @default(cuid())
  userAId       String?          @map("user_a_id")
  userBId       String?          @map("user_b_id")
  userAName     String           @map("user_a_name")
  userACompany  String?          @map("user_a_company")
  userBName     String           @map("user_b_name")
  userBCompany  String?          @map("user_b_company")
  source        ConnectionSource
  originContext String?          @map("origin_context")
  eventId       String?          @map("event_id")
  eventName     String?          @map("event_name")
  depth         Int              @default(1)
  aiScore       Int?             @map("ai_score")
  status        ConnectionStatus @default(ACTIVE)
  createdAt     DateTime         @default(now()) @map("created_at")

  event        Event?                  @relation(fields: [eventId], references: [id], onDelete: SetNull)
  userA        User?                   @relation("ConnectionUserA", fields: [userAId], references: [id], onDelete: SetNull)
  userB        User?                   @relation("ConnectionUserB", fields: [userBId], references: [id], onDelete: SetNull)
  interactions ConnectionInteraction[]

  @@map("business_connections")
}

model ConnectionInteraction {
  id           String   @id @default(cuid())
  connectionId String   @map("connection_id")
  type         String
  description  String
  occurredAt   DateTime @default(now()) @map("occurred_at")

  connection BusinessConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@map("connection_interactions")
}

model PointsLedger {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  amount    Int
  reason    PointsReason
  note      String?
  createdAt DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("points_ledger")
}

model PointsRedemption {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  benefitName String   @map("benefit_name")
  pointsSpent Int      @map("points_spent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("points_redemptions")
}

model FeedItem {
  id            String       @id @default(cuid())
  userId        String       @map("user_id")
  type          FeedItemType
  content       String
  aiScore       Int?         @map("ai_score")
  triggerReason String?      @map("trigger_reason")
  createdAt     DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feed_items")
}

model SnSession {
  id         String          @id @default(cuid())
  eventId    String          @map("event_id")
  status     SnSessionStatus @default(SCHEDULED)
  roundCount Int             @default(1) @map("round_count")
  startedAt  DateTime?       @map("started_at")
  endedAt    DateTime?       @map("ended_at")
  createdAt  DateTime        @default(now()) @map("created_at")

  event Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pairs SnPair[]

  @@map("sn_sessions")
}

model SnPair {
  id                    String   @id @default(cuid())
  sessionId             String   @map("session_id")
  participantAId        String   @map("participant_a_id")
  participantBId        String   @map("participant_b_id")
  round                 Int      @default(1)
  ratingA               Int?     @map("rating_a")
  ratingB               Int?     @map("rating_b")
  connectionEstablished Boolean  @default(false) @map("connection_established")
  createdAt             DateTime @default(now()) @map("created_at")

  session      SnSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participantA Participant @relation("SnPairParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB Participant @relation("SnPairParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)

  @@map("sn_pairs")
}

model InviteCampaign {
  id             String               @id @default(cuid())
  eventId        String               @map("event_id")
  createdBy      String?              @map("created_by")
  name           String
  channel        InviteChannel
  status         InviteCampaignStatus @default(DRAFT)
  templateId     String?              @map("template_id")
  subject        String?
  customMessage  String?              @map("custom_message")
  targetFilter   Json                 @default("{}") @map("target_filter")
  totalTarget    Int                  @default(0) @map("total_target")
  sentCount      Int                  @default(0) @map("sent_count")
  deliveredCount Int                  @default(0) @map("delivered_count")
  clickedCount   Int                  @default(0) @map("clicked_count")
  activatedCount Int                  @default(0) @map("activated_count")
  failedCount    Int                  @default(0) @map("failed_count")
  scheduledAt    DateTime?            @map("scheduled_at")
  startedAt      DateTime?            @map("started_at")
  completedAt    DateTime?            @map("completed_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  event   Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  creator User?          @relation("CampaignCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  records InviteRecord[]

  @@index([eventId, status])
  @@map("invite_campaigns")
}

model InviteRecord {
  id              String             @id @default(cuid())
  campaignId      String             @map("campaign_id")
  participantId   String             @map("participant_id")
  userId          String?            @map("user_id")
  channel         InviteChannel
  destination     String
  activationToken String             @unique @default(cuid()) @map("activation_token")
  tokenExpiresAt  DateTime           @map("token_expires_at")
  status          InviteRecordStatus @default(PENDING)
  sentAt          DateTime?          @map("sent_at")
  deliveredAt     DateTime?          @map("delivered_at")
  clickedAt       DateTime?          @map("clicked_at")
  activatedAt     DateTime?          @map("activated_at")
  vendorMessageId String?            @map("vendor_message_id")
  errorMessage    String?            @map("error_message")
  retryCount      Int                @default(0) @map("retry_count")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  campaign    InviteCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participant Participant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([campaignId, participantId])
  @@index([campaignId, status])
  @@index([activationToken])
  @@map("invite_records")
}
