generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLATFORM_ADMIN
  ORGANIZER
  EXPO_ORGANIZER
  EXHIBITOR
}

enum EventType {
  CONFERENCE
  EXPO
}

/// 活动类型（决定管理端菜单与能力）
enum ActivityType {
  CONFERENCE // 会议/论坛/沙龙
  EXPO // 展会（含展位/展商管理）
  EXHIBITION // 参展（展商运营：互动/抽奖/线索）
}

/// 活动数据来源
enum DataSource {
  NATIVE // ConnectIQ 原生创建
  BAGEVENT // 百格导入
  MARKETUP // MarketUP 导入
}

enum EventStatus {
  DRAFT
  PUBLISHED
  LIVE
  ARCHIVED
}

enum ParticipantRole {
  ATTENDEE
  SPEAKER
}

enum BoothStatus {
  AVAILABLE
  BOOKED
  OCCUPIED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  WON
}

enum CrmSyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum TicketStatus {
  ISSUED
  USED
  CANCELLED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum PollType {
  SINGLE_CHOICE
  MULTI_CHOICE
  WORD_CLOUD
  RATING
  SURVEY
  QNA
  ANNOUNCEMENT
}

enum PollStatus {
  DRAFT
  LIVE
  PAUSED
  CLOSED
}

enum AiMatchScenario {
  PARTICIPANT_PEER
  EXHIBITOR_TO_BUYER
  BUYER_TO_EXHIBITOR
}

enum AiMatchAction {
  PENDING
  VIEWED
  CONTACTED
  MEETING_BOOKED
  IGNORED
}

enum AiGenerationType {
  SCAN_BRIEF
  CONNECTION_NOTE
  FOLLOWUP_EMAIL
  INTRO_MESSAGE
  MONTHLY_INSIGHT
  INTENT_PARSE
}

enum AiPromptStatus {
  ACTIVE
  DEPRECATED
}

enum AiQualityRating {
  EXCELLENT
  PASS
  NEEDS_WORK
}

enum MonthlyInsightStatus {
  PENDING
  GENERATED
  FAILED
}

enum AiFeedbackType {
  MATCH_USEFUL
  MATCH_USELESS
  TIMING_ACCURATE
  TIMING_INACCURATE
  CONTENT_QUALITY
  CONTENT_POOR
}

/// 推荐配对反馈信号（采纳 / 忽略 / 婉拒）
enum MatchFeedbackSignal {
  EXCHANGED
  MEETING
  VIEWED
  IGNORED
  DECLINED
}

enum IntentCategory {
  TRADING
  INVESTING
  PARTNERING
  RECRUITING
  NETWORKING
}

enum IntentTagPool {
  SUPPLY
  DEMAND
  TOPIC
  GENERAL
}

enum SnSessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserAccountStatus {
  SHADOW
  ACTIVE
  COMPLETE
  BANNED
}

enum RegistrationSource {
  EMAIL
  PHONE
  WECHAT
  IMPORT
}

enum ConnectionSource {
  SCAN
  AI_RECOMMEND
  SPEED_NETWORKING
  REFERRAL
}

enum ConnectionStatus {
  ACTIVE
  INACTIVE
  DISCONNECTED
}

enum ExchangeMethod {
  FACE_TO_FACE // 面对面，双方确认
  DEFERRED // 异步：A 请求，B 稍后确认
  MY_CARD_SCANNED // 对方扫了我展示的名片码
}

enum ExchangeStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum PointsReason {
  CHECKIN
  CONNECTION
  INTERACTION
  PROFILE
  REFERRAL
  REDEMPTION
  ADJUSTMENT
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum MeetingStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum FeedItemType {
  MATCH
  AI_REFERRAL
  INSIGHT
  REMINDER
  SYSTEM
}

enum SignalType {
  BOOTH_SCAN
  BOOTH_LEAD_CAPTURED
  POLL_ANSWERED
  QNA_ASKED
  QNA_UPVOTED
  INTERACTION_JOINED
  CONNECTION_MADE
  MEETING_BOOKED
}

enum StampRallyStatus {
  DRAFT
  ACTIVE
  ENDED
}

enum StampOwnerType {
  ORGANIZER
  EXHIBITOR
}

enum StampCollectMethod {
  SCAN
  NFC
}

enum InviteCampaignStatus {
  DRAFT
  SENDING
  SENT
  FAILED
  SCHEDULED
}

enum InviteChannel {
  SMS
  EMAIL
  WECHAT
}

enum InviteRecordStatus {
  PENDING
  SENT
  DELIVERED
  CLICKED
  ACTIVATED
  FAILED
  SKIPPED
}

enum ParticipantInviteStatus {
  NOT_INVITED
  INVITED
  CLICKED
  ACTIVATED
}

enum LotteryType {
  RANDOM
  QUIZ_BASED
  CHECKIN_BASED
  ACTIVITY_BASED
}

/// 抽奖归属：主办方全场 / 展商展位
enum LotteryOwnerType {
  ORGANIZER
  EXHIBITOR
}

/// 开奖方式
enum LotteryDrawType {
  INSTANT
  SCHEDULED
  MANUAL
}

enum LotteryStatus {
  DRAFT
  ACTIVE
  DRAWING
  ENDED
  READY
  OPEN
  FINISHED
}

enum PrizeType {
  PHYSICAL
  DIGITAL
  EXPERIENCE
}

enum LotteryEntrySource {
  MANUAL
  AUTO_CHECKIN
  AUTO_ACTIVITY
}

enum InteractionChannelType {
  QR_CODE
  LINK
  APP_PUSH
}

enum InteractionOwnerType {
  ORGANIZER
  EXHIBITOR
}

// 用户类型（区分三层角色）
enum UserType {
  END_USER // 移动端最终用户（参会者/买家/B2B专业人士）
  ACCOUNT_ADMIN // 账号管理员（主办方/展会方/参展商，需审核）
  PLATFORM_ADMIN // 平台超级管理员（ConnectIQ 内部运营）
}

// 账号管理员的审核状态
enum AdminStatus {
  PENDING_REVIEW // 已提交申请，等待审核
  TRIAL // 自助试用，可创建活动体验核心功能
  APPROVED // 审核通过，可正常使用管理端
  REJECTED // 审核拒绝（附原因）
  SUSPENDED // 已暂停（违规或其他原因）
}

// 账号类型（历史字段，Organization.account_type 保留兼容，新逻辑不再读取）
enum AccountType {
  ORGANIZATION
  CONFERENCE_ORGANIZER
  EXPO_ORGANIZER
  EXHIBITOR
}

// 申请审核状态
enum ApplicationStatus {
  PENDING // 待审核
  APPROVED // 通过
  REJECTED // 拒绝
}

// 活动发布状态（账号已审核，活动无需平台再审）
enum ReviewStatus {
  DRAFT
  PUBLISHED
  LIVE
  ENDED
}

// 平台活动审核状态（EventReview 历史流程）
enum EventReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  REVISION_REQUIRED
}

// 用户加入组织的来源
enum OrgJoinSource {
  PARTICIPATED_EVENT // 参加了该组织举办的活动
  LEAD_CAPTURED // 在展会上被展商扫码采集
  INVITED // 通过该组织发送的邀请链接激活
  FOLLOWED // 主动关注了组织账号主页
  QR_SCANNED // 扫码参与互动（InteractionSession）
}

// 组织内用户价值层级（账号管理员视角）
enum MemberTier {
  VIP // 高价值，多次参与，重点维护
  ACTIVE // 活跃，近期有参与行为
  REGULAR // 普通用户
  DORMANT // 沉睡用户，长期未活跃
}

// 组织内部团队角色
enum OrgStaffRole {
  OWNER // 创建者（唯一，不可删除）
  ADMIN // 管理员（可管理所有功能）
  OPERATOR // 操作员（只能管理具体活动，不能管用户池）
  VIEWER // 只读
}

// 组织团队成员邀请状态
enum InviteStatus {
  INVITED
  ACCEPTED
  DECLINED
  REVOKED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  phone        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roleAssignments            UserRoleAssignment[]
  organizedEvents            Event[]              @relation("EventOrganizer")
  createdPolls               Poll[]               @relation("PollCreator")
  notifications              Notification[]
  auditLogs                  AuditLog[]
  fileAssets                 FileAsset[]
  apiKeys                    ApiKey[]
  monthlyInsights            MonthlyInsight[]
  aiFeedbacks                AiFeedback[]
  profile                    UserProfile?
  identities                 UserIdentity[]
  pointsLedger               PointsLedger[]
  feedItems                  FeedItem[]
  connectionsAsA             BusinessConnection[] @relation("ConnectionUserA")
  connectionsAsB             BusinessConnection[] @relation("ConnectionUserB")
  createdCampaigns           InviteCampaign[]     @relation("CampaignCreator")
  inviteRecords              InviteRecord[]
  createdLotteries           Lottery[]            @relation("LotteryCreator")
  lotteryEntries             LotteryEntry[]
  lotteryWins                LotteryWinner[] @relation("LotteryWinnerUser")
  lotteryWinVerifications    LotteryWinner[] @relation("LotteryWinnerVerifier")
  createdInteractionSessions InteractionSession[] @relation("InteractionSessionCreator")
  referralsIntroduced        BusinessReferral[]   @relation("ReferralIntroducer")
  referralsReceived          BusinessReferral[]   @relation("ReferralRecipient")
  referralsAsA               BusinessReferral[]   @relation("ReferralUserA")
  referralsAsB               BusinessReferral[]   @relation("ReferralUserB")
  requestedMeetings          Meeting[]            @relation("MeetingRequester")
  receivedMeetings           Meeting[]            @relation("MeetingRecipient")
  boothVisitSignals          BoothVisitSignal[]
  createdStampRallies        StampRally[]         @relation("StampRallyCreator")
  stampRecords               StampRecord[]
  stampRallyWins             StampRallyWinner[]
  userStamps                 UserStamp[]
  userStampProgresses        UserStampProgress[]
  contactCard                ContactCard?
  sentExchangeRequests       ExchangeRequest[]    @relation("ExchangeFrom")
  receivedExchangeRequests   ExchangeRequest[]    @relation("ExchangeTo")
  userEventIntents           UserEventIntent[]
  matchBriefsAsViewer        MatchBrief[]         @relation("MatchBriefViewer")
  matchBriefsAsTarget        MatchBrief[]         @relation("MatchBriefTarget")
  matchFeedbacksAsViewer     MatchFeedback[]      @relation("MatchFeedbackViewer")
  matchFeedbacksAsTarget     MatchFeedback[]      @relation("MatchFeedbackTarget")

  // 三层角色区分
  userType UserType @default(END_USER) @map("user_type")

  // 用户所属账号（审核通过后可发布任意类型活动，无多组织切换）
  orgId String?       @map("org_id")
  org   Organization? @relation("UserOrg", fields: [orgId], references: [id], onDelete: SetNull)

  // 组织关联
  ownedOrg              Organization?          @relation("OrgOwner")
  orgMemberships        OrgMember[]
  orgStaffRoles         OrgStaff[]             @relation("OrgStaffMember")
  orgStaffInvites       OrgStaff[]             @relation("OrgStaffInviter")
  submittedApplications OrganizerApplication[]
  reviewedApplications  OrganizerApplication[] @relation("ApplicationReviewer")
  organizerTrialProfiles OrganizerTrialProfile[]
  submittedEventReviews EventReview[]          @relation("EventReviewSubmitter")
  reviewedEventReviews  EventReview[]          @relation("EventReviewer")
  operatedBooths        ExhibitorBooth[]       @relation("BoothOperator")

  @@map("users")
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  role      UserRole
  entityId  String?  @map("entity_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role, entityId])
  @@map("user_role_assignments")
}

model Organization {
  id String @id @default(cuid())

  name    String
  slug    String  @unique
  logoUrl String? @map("logo_url")
  coverUrl String? @map("cover_url")
  bio     String?
  website String?
  contactEmail String? @map("contact_email")

  industry     String? @map("industry")
  companySize  String? @map("company_size")
  headquarters String? @map("headquarters")
  foundedYear  Int?    @map("founded_year")

  /// @deprecated 历史字段，迁移后不再读取
  accountType AccountType? @map("account_type")

  orgCreditCode String?     @map("org_credit_code")
  isVerified    Boolean     @default(false) @map("is_verified")
  /// B 端账号审核/试用状态（主办方/展商客户，非参会者）
  adminStatus   AdminStatus @default(PENDING_REVIEW) @map("admin_status")

  /// B 端跨活动累计（账号留存维度，非 C 端参会者社交图谱）
  totalEvents       Int @default(0) @map("total_events")
  totalParticipants Int @default(0) @map("total_participants")
  totalLeads        Int @default(0) @map("total_leads")
  totalConnections  Int @default(0) @map("total_connections")

  memberCount   Int @default(0) @map("member_count")
  eventCount    Int @default(0) @map("event_count")
  followerCount Int @default(0) @map("follower_count")

  ownerId String? @unique @map("owner_id")
  owner   User?   @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  users           User[]                @relation("UserOrg")
  members         OrgMember[]
  staff           OrgStaff[]
  events          Event[]
  application     OrganizerApplication?
  exhibitorBooths ExhibitorBooth[]      @relation("BoothOrg")
  trialProfile    OrganizerTrialProfile?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([adminStatus])
  @@index([slug])
  @@map("organizations")
}

model OrgMember {
  id     String       @id @default(cuid())
  orgId  String       @map("org_id")
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String       @map("user_id")
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// C 端参会者与组织的关系（用户池/营销触达，非 B2B 持久社交）
  joinSource    OrgJoinSource @map("join_source")
  sourceEventId String?       @map("source_event_id")
  sourceEvent   Event?        @relation("MemberSourceEvent", fields: [sourceEventId], references: [id], onDelete: SetNull)

  // 关注状态
  isFollowing  Boolean @default(false) @map("is_following")
  isSubscribed Boolean @default(false) @map("is_subscribed")

  // 用户价值标签（账号管理员视角，不对用户显示）
  tier  MemberTier @default(REGULAR)
  tags  String[]   @default([])
  notes String?

  // 活跃度统计
  eventCount   Int       @default(0) @map("event_count")
  firstSeenAt  DateTime  @default(now()) @map("first_seen_at")
  lastActiveAt DateTime? @map("last_active_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([orgId, userId])
  @@index([orgId, tier])
  @@index([orgId, lastActiveAt])
  @@index([orgId, isFollowing])
  @@map("org_members")
}

model OrgStaff {
  id     String       @id @default(cuid())
  orgId  String       @map("org_id")
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String       @map("user_id")
  user   User         @relation("OrgStaffMember", fields: [userId], references: [id], onDelete: Cascade)

  /// B 端账号管理员（主办方/展商），保留跨活动历史与累计数据
  role      OrgStaffRole
  invitedBy String?      @map("invited_by")
  inviter   User?        @relation("OrgStaffInviter", fields: [invitedBy], references: [id], onDelete: SetNull)
  status    InviteStatus @default(INVITED)

  invitedAt  DateTime  @default(now()) @map("invited_at")
  acceptedAt DateTime? @map("accepted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([orgId, userId])
  @@map("org_staff")
}

model OrganizerTrialProfile {
  id     String @id @default(cuid())
  orgId  String @unique @map("org_id")
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  signupSource String @default("self_service_organizer") @map("signup_source")
  companyName  String @map("company_name")
  contactName  String? @map("contact_name")

  trialStartedAt DateTime @default(now()) @map("trial_started_at")
  lastActiveAt   DateTime @default(now()) @map("last_active_at")

  eventsCreated        Int @default(0) @map("events_created")
  eventsPublished      Int @default(0) @map("events_published")
  participantsImported Int @default(0) @map("participants_imported")
  connectionsTotal     Int @default(0) @map("connections_total")
  leadsTotal           Int @default(0) @map("leads_total")
  conversionScore      Int @default(0) @map("conversion_score")

  firstEventAt      DateTime? @map("first_event_at")
  firstImportAt     DateTime? @map("first_import_at")
  firstPublishedAt  DateTime? @map("first_published_at")
  firstConnectionAt DateTime? @map("first_connection_at")

  conversionSignals Json @default("[]") @map("conversion_signals")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([trialStartedAt])
  @@map("organizer_trial_profiles")
}

/// 向上转化钩子展示/点击/关闭追踪（BAGEVENT / MARKETUP）
model ConversionHookEvent {
  id     String @id @default(cuid())
  userId String @map("user_id")
  orgId  String? @map("org_id")

  target  String
  context String
  trigger String
  action  String

  eventId String? @map("event_id")
  boothId String? @map("booth_id")
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([target, context, action, createdAt])
  @@index([userId, target, context, trigger])
  @@index([orgId, createdAt])
  @@map("conversion_hook_events")
}

model OrganizerApplication {
  id     String        @id @default(cuid())
  userId String        @map("user_id") // 同一用户可多次申请（不同组织）
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId  String?       @unique @map("org_id")
  org    Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  // 申请信息
  accountType   AccountType @map("account_type")
  orgName       String      @map("org_name")
  orgCreditCode String?     @map("org_credit_code")
  orgWebsite    String?     @map("org_website")
  contactName   String      @map("contact_name")
  contactEmail  String      @map("contact_email")
  contactPhone  String      @map("contact_phone")
  description   String

  // 审核
  status          ApplicationStatus @default(PENDING)
  rejectionReason String?           @map("rejection_reason")
  reviewerNotes   String?           @map("reviewer_notes")
  reviewedBy      String?           @map("reviewed_by")
  reviewer        User?             @relation("ApplicationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?         @map("reviewed_at")

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([accountType, status])
  @@map("organizer_applications")
}

model EventReview {
  id          String @id @default(cuid())
  eventId     String @unique @map("event_id")
  event       Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  submittedBy String @map("submitted_by")
  submitter   User?  @relation("EventReviewSubmitter", fields: [submittedBy], references: [id], onDelete: SetNull)

  status          EventReviewStatus @default(PENDING_REVIEW)
  rejectionReason String?      @map("rejection_reason")
  revisionNotes   String?      @map("revision_notes")
  reviewerNotes   String?      @map("reviewer_notes")

  reviewedBy String?   @map("reviewed_by")
  reviewer   User?     @relation("EventReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt DateTime? @map("reviewed_at")

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("event_reviews")
}

model Event {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  type         EventType
  activityType ActivityType @default(CONFERENCE) @map("activity_type")
  status       EventStatus  @default(DRAFT)
  description  String?
  location     String?
  startDate    DateTime?    @map("start_date")
  endDate      DateTime?    @map("end_date")
  organizerId  String       @map("organizer_id")
  orgId        String       @map("org_id")
  reviewStatus ReviewStatus @default(DRAFT) @map("review_status")
  dataSource   DataSource   @default(NATIVE) @map("data_source")
  externalRefId String?     @map("external_ref_id")
  featureFlags Json           @default("{}") @map("feature_flags")
  meetingEnabled       Boolean   @default(true) @map("meeting_enabled")
  meetingSlotMinutes   Int       @default(20) @map("meeting_slot_minutes")
  meetingOpenAt        DateTime? @map("meeting_open_at")
  meetingBufferMinutes Int       @default(5) @map("meeting_buffer_minutes")
  intentConfig         Json      @default("{}") @map("intent_config")
  premeetEnabled       Boolean   @default(false) @map("premeet_enabled")
  premeetOpenAt        DateTime? @map("premeet_open_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  organizer           User                 @relation("EventOrganizer", fields: [organizerId], references: [id])
  org                 Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  review              EventReview?
  orgMembers          OrgMember[]          @relation("MemberSourceEvent")
  settings            EventSetting[]
  halls               ExpoHall[]
  booths              ExhibitorBooth[]
  participants        Participant[]
  intentTags          IntentTag[]
  ticketTypes         TicketType[]
  sessions            Session[]
  speakers            Speaker[]
  sponsors            Sponsor[]
  invitations         Invitation[]
  checkIns            CheckIn[]
  surveys             Survey[]
  polls               Poll[]
  externalSyncs       ExternalSync[]
  crmSyncJobs         CrmSyncJob[]
  aiMatchResults      AiMatchResult[]
  businessConnections BusinessConnection[]
  businessReferrals   BusinessReferral[]
  meetings            Meeting[]
  meetingAreas        MeetingArea[]
  snSessions          SnSession[]
  inviteCampaigns     InviteCampaign[]
  lotteries           Lottery[]
  interactionSessions InteractionSession[]
  aiReferralScans     AIReferralScan[]
  feedItems           FeedItem[]
  boothVisitSignals   BoothVisitSignal[]
  stampRallies        StampRally[]
  exchangeRequests    ExchangeRequest[]
  userEventIntents    UserEventIntent[]
  matchBriefs         MatchBrief[]
